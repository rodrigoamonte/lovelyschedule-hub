# Configuração de Redes
# Porta onde a aplicação frontend será exposta no host
APP_PORT_HOST=8080
# Porta interna da API
API_PORT=3000

# Base de Dados (MySQL)
# Host 'db' refere-se ao serviço definido no docker-compose.yml
DB_HOST=db
DB_NAME=agendlog
DB_USER=root
# Gerar senha segura: openssl rand -base64 32
DB_ROOT_PASSWORD=

# Autenticação e Segurança
# Gerar segredo JWT: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=5d

# Credenciais do Administrador Inicial
ADMIN_EMAIL=admin@agendlog.com
# Gerar senha segura: openssl rand -base64 12
ADMIN_PASSWORD=

# Configurações do Frontend (Vite)
VITE_API_URL=http://localhost/api/v1
VITE_APP_NAME=Agendlog

# Ambiente (development | production)
ENVIRONMENT=development
